ALERT_EMAIL="youremail@goeshere.com"

# How long to wait before the recheck that decides whether to alert via email.
# I chose 5 minutes.
RETRY_DELAY_SECONDS=300

# Timeouts for probes.
CURL_CONNECT_TIMEOUT=10
CURL_MAX_TIME=20
TCP_CONNECT_TIMEOUT=10

# Critical checks: I set these in the script to run every 15 minutes.
CRITICAL_CHECKS=(
  "nextcloud|http|https://cloud.yourdomain.com/status.php|Nextcloud"
  "wordpress-site|http|https://wordpresssite.com|WordPress Site"
  "static-site|http|https://staticsite.com|Static Site"
)

# Hourly checks: In my setup, these are sites unlikely to fail on their own, so they are checked less often for efficiency.
HOURLY_CHECKS=(
  # WordPress
  "wordpress-2|http|https://wordpresssite2.ch|WordPress Site 2"

  # Static
  "another-static-site|http|https://another-static-site.com|Another Static Site"

  # Other services, just examples given here
  "authelia|http|https://authelia.yourdomain.com|Authelia"
  "immich|http|https://immich.yourdomain.com|Immich"
)
